{
  "name": "dsqlbase",
  "version": "1.0.0",
  "description": "Starter template for TypeScript projects",
  "main": "turbo.json",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/dsqlbase.git"
  },
  "author": "sls.dev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/slsdotdev/dsqlbase/issues"
  },
  "homepage": "https://github.com/slsdotdev/dsqlbase#readme",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.11.0",
    "yarn": "use-npm",
    "pnpm": "use-npm"
  },
  "scripts": {
    "prepare": "husky",
    "test": "turbo run test",
    "coverage": "turbo run test -- --coverage",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "changeset": "changeset",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.9.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  },
  "workspaces": [
    "packages/*"
  ]
}
