{
  "name": "@dsqlbase/schema",
  "version": "0.0.1",
  "description": "Schema definition and migration tools for DSQLBase",
  "sideEffects": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./migrations": {
      "default": "./dist/migrations/index.js",
      "types": "./dist/migrations/index.d.ts"
    },
    "./migrations/*": {
      "default": "./dist/migrations/*.js",
      "types": "./dist/migrations/*.d.ts"
    },
    "./definition": {
      "default": "./dist/definition/index.js",
      "types": "./dist/definition/index.d.ts"
    },
    "./definition/*": {
      "default": "./dist/definition/*.js",
      "types": "./dist/definition/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest dev",
    "lint": "eslint src --ext .ts",
    "dev": "vitest watch"
  },
  "dependencies": {
    "@dsqlbase/core": "^0.0.1"
  }
}
