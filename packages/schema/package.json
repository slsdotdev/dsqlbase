{
  "name": "@dsqlbase/schema",
  "version": "0.1.0",
  "description": "Schema definition and migration tools for DSQLBase",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "sls.dev",
    "email": "dev@sls.dev",
    "url": "https://www.sls.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.sls.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/dsqlbase.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/slsdotdev/dsqlbase/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "../../LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./migration": {
      "default": "./dist/migration/index.js",
      "types": "./dist/migration/index.d.ts"
    },
    "./migration/*": {
      "default": "./dist/migration/*.js",
      "types": "./dist/migration/*.d.ts"
    },
    "./definition": {
      "default": "./dist/definition/index.js",
      "types": "./dist/definition/index.d.ts"
    },
    "./definition/*": {
      "default": "./dist/definition/*.js",
      "types": "./dist/definition/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest dev"
  },
  "dependencies": {
    "@dsqlbase/core": "^0.1.0"
  }
}
