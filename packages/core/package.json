{
  "name": "@dsqlbase/core",
  "version": "0.1.2",
  "description": "Core primitives and utilities for dsqlbase",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "sls.dev",
    "email": "dev@sls.dev",
    "url": "https://www.sls.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.sls.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/dsqlbase.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/slsdotdev/dsqlbase/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "../../LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./definition": {
      "default": "./dist/definition/index.js",
      "types": "./dist/definition/index.d.ts"
    },
    "./definition/*": {
      "default": "./dist/definition/*.js",
      "types": "./dist/definition/*.d.ts"
    },
    "./runtime": {
      "default": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./runtime/*": {
      "default": "./dist/runtime/*.js",
      "types": "./dist/runtime/*.d.ts"
    },
    "./sql": {
      "default": "./dist/sql/index.js",
      "types": "./dist/sql/index.d.ts"
    },
    "./sql/*": {
      "default": "./dist/sql/*.js",
      "types": "./dist/sql/*.d.ts"
    },
    "./utils": {
      "default": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./utils/*": {
      "default": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  }
}
