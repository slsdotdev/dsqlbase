{
  "name": "dsqlbase",
  "version": "0.1.2",
  "description": "Query client and schema definition for distributed SQL databases",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "sls.dev",
    "email": "dev@sls.dev",
    "url": "https://www.sls.dev"
  },
  "keywords": [
    "SQL",
    "Aurora DSQL",
    "PostgreSQL"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.sls.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slsdotdev/dsqlbase.git",
    "directory": "packages/dsqlbase"
  },
  "bugs": {
    "url": "https://github.com/slsdotdev/dsqlbase/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "../../LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "default": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./pg": {
      "default": "./dist/pg/index.js",
      "types": "./dist/pg/index.d.ts"
    },
    "./pglite": {
      "default": "./dist/pglite/index.js",
      "types": "./dist/pglite/index.d.ts"
    },
    "./schema": {
      "default": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@dsqlbase/core": "^0.1.2"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "pg": "^8.20.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "@electric-sql/pglite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
